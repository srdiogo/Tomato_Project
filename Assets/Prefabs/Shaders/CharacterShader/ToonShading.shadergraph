{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "b2f8d87987bc4015b833784dc6772b6d",
    "m_Group": {
        "m_Id": "4aa6576c4c65465d86147d20f81bfc90"
    },
    "m_Name": "ToonShading (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -2276.000244140625,
            "y": -79.0000228881836,
